# Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (Required)
# - URL + anon key power both browser and server clients (auth, RLS reads/writes)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (Server-side only, NEVER expose to the client)
# Required for: admin user listing, freeze/delete, password reset link generation,
# and the orphan-profile reconcile endpoint (/api/admin/users/reconcile).
# Without this key, /admin/users will report "Admin client not configured".
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Management API (used only by scripts/_push-one.cjs to apply migrations)
# Generate the access token at https://supabase.com/dashboard/account/tokens
# Project ID is the project reference under Project Settings → General.
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_ACCESS_TOKEN=sbp_your-management-api-token

# Public site URL (used for OAuth redirect when VERCEL_URL is unavailable, e.g. local dev)
# Set this in production to avoid falling back to https://everloop.live.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI (Required for AI features)
OPENAI_API_KEY=your-openai-api-key

# Meshy AI (3D model generation)
MESHY_API_KEY=your-meshy-api-key

# ElevenLabs (Voice TTS + Sound Effects)
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================
# Resend Email Service
# ============================================
# Domain: everloop.live
# Sign up at: https://resend.com
RESEND_API_KEY=your-resend-api-key

# DNS Records for Resend (configured in GoDaddy)
# ============================================
# These records are already configured - DO NOT CHANGE unless troubleshooting
